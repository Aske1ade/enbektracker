# Public address (IP or domain) used by users to open the app.
# Example:
# SERVER_HOST=203.0.113.10
# SERVER_HOST=tracker.example.com
SERVER_HOST=your-server-ip-or-domain

# Runtime environment
ENVIRONMENT=production
PROJECT_NAME="Corporate Task Tracker"

# Exposed frontend port on the server
APP_PORT=80

# Internal debugging ports (bound only to 127.0.0.1 by docker-compose.server.yml)
BACKEND_PORT=8888
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Backend
BACKEND_CORS_ORIGINS="http://your-server-ip-or-domain,https://your-server-ip-or-domain"
SECRET_KEY=replace-with-long-random-secret
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=replace-with-strong-password
USERS_OPEN_REGISTRATION=False

# Emails (optional)
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# Postgres
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-db-password

# Monitoring (optional)
SENTRY_DSN=

# MinIO
MINIO_ROOT_USER=tracker_minio_admin
MINIO_ROOT_PASSWORD=replace-with-strong-minio-password
MINIO_BUCKET=task-attachments
MINIO_SECURE=False
MINIO_REGION=

# Attachment validation
ATTACHMENTS_MAX_SIZE_MB=10
ATTACHMENTS_ALLOWED_CONTENT_TYPES=["text/plain","application/pdf","image/png","image/jpeg","application/vnd.openxmlformats-officedocument.spreadsheetml.sheet","application/vnd.ms-excel"]

# Deadline thresholds and background jobs
DEFAULT_DEADLINE_YELLOW_DAYS=3
DEFAULT_DEADLINE_NORMAL_DAYS=5
TRACKER_BACKGROUND_JOBS_ENABLED=True
TASK_DEADLINE_RECALC_INTERVAL_SECS=120

# Desktop-agent download endpoint options:
# 1) serve local file from backend host if DESKTOP_AGENT_BINARY_PATH exists
# 2) otherwise redirect to DESKTOP_AGENT_DOWNLOAD_URL
DESKTOP_AGENT_DOWNLOAD_URL=
# This path is inside backend container.
# By default docker-compose.server.yml mounts ${AGENT_DOWNLOADS_DIR} -> /opt/enbektracker/downloads
DESKTOP_AGENT_BINARY_PATH=/opt/enbektracker/downloads/EnbekTracker_0.1.0_x64-setup.exe
# Path on server host (folder with installer .exe)
AGENT_DOWNLOADS_DIR=./deploy/desktop-agent

# Python package source for backend image build.
# If pypi.org is blocked in your network, set your mirror URL, e.g.:
# PIP_INDEX_URL=https://pypi.org/simple
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_INDEX_URL=https://pypi.org/simple
PIP_EXTRA_INDEX_URL=
# Optional for TLS interception/proxy environments (host only, no scheme).
# Multiple hosts are supported, separated by space/comma/semicolon.
# Example: PIP_TRUSTED_HOST=pypi.org,files.pythonhosted.org
PIP_TRUSTED_HOST=
