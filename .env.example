# Domain
DOMAIN=localhost

# Environment: local, staging, production
ENVIRONMENT=local

PROJECT_NAME="Corporate Task Tracker"
STACK_NAME=full-stack-fastapi-project

# Backend
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:5173"
SECRET_KEY=local-dev-secret-key-rotate-before-prod
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=local-admin-pass-123
USERS_OPEN_REGISTRATION=False

# Emails
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# Postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=local-postgres-pass-123

SENTRY_DSN=

# MinIO
MINIO_ROOT_USER=tracker_minio_admin
MINIO_ROOT_PASSWORD=tracker_minio_pass_123
MINIO_BUCKET=task-attachments
MINIO_SECURE=False
MINIO_REGION=

# Attachment validation
ATTACHMENTS_MAX_SIZE_MB=10
ATTACHMENTS_ALLOWED_CONTENT_TYPES=["text/plain","application/pdf","image/png","image/jpeg","application/vnd.openxmlformats-officedocument.spreadsheetml.sheet","application/vnd.ms-excel"]

# Deadline thresholds
DEFAULT_DEADLINE_YELLOW_DAYS=3
DEFAULT_DEADLINE_NORMAL_DAYS=5
TRACKER_BACKGROUND_JOBS_ENABLED=True
TASK_DEADLINE_RECALC_INTERVAL_SECS=120

# Desktop-agent download
# If DESKTOP_AGENT_BINARY_PATH points to a local .exe file on backend host,
# /api/v1/utils/desktop-agent/download serves that file directly.
# Otherwise backend redirects to DESKTOP_AGENT_DOWNLOAD_URL.
DESKTOP_AGENT_DOWNLOAD_URL=
DESKTOP_AGENT_BINARY_PATH=

# Configure these with your own Docker registry images
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend
